; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Norte"
run/main_scene="res://scenes/menu/menu.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://Sprites/Inteface/icono.png"

[autoload]

DataManager="*res://scenes/data_manager/data_manager.gd"
SceneTransition="*res://scenes/effects/scene_transition.gd"
AudioManager="*res://scenes/audio/audio_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/initial_position_type=0
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom_font="res://Fuentes/Pixel Sans Serif.ttf"

[input_devices]

pointing/android/enable_touch=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
